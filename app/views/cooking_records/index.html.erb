<div class="max-w-6xl mx-auto mt-6 md:mt-10 mb-20 px-4">
  <div class="mb-8 md:mb-12">
    <h1 class="text-2xl md:text-3xl font-black text-stone-800 tracking-tight flex items-center gap-2">
      <span class="text-orange-500 text-3xl md:text-4xl">🕰️</span>
      これまでの自炊記録一覧
    </h1>
    <p class="text-stone-400 text-xs md:text-sm mt-1 font-medium">
      レシピごとの累計実績を確認できます。
    </p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 md:gap-10">
    <% if @cooking_records.any? %>
      <% @cooking_records.each_with_index do |record, index| %>
        <% recipe = record.recipe %>
        <%# 合計金額から節約額を計算 %>
        <% total_savings = record.total_convenience_cost - record.total_cooking_cost %>

        <div class="animate-fade-in-up bg-white rounded-[2rem] border border-orange-50 shadow-sm overflow-hidden flex flex-col"
             style="animation-delay: <%= index * 0.05 %>s; opacity: 0; animation-fill-mode: forwards;">
            
            <div class="relative overflow-hidden aspect-square md:aspect-[4/3] bg-stone-100"> 
              <% if recipe&.image&.attached? %>
                <%= image_tag recipe.image, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-stone-300">
                  <span class="text-4xl">🍽️</span>
                </div>
              <% end %>

              <div class="absolute top-2 right-2 bg-orange-500 text-white py-1 px-3 rounded-full text-[10px] font-black shadow-lg">
                <%= record.count %>回目
              </div>

              <div class="absolute top-2 left-2 bg-black/50 backdrop-blur-md text-white py-1 px-3 rounded-full text-[10px] font-bold">
                <%= l record.latest_cooked_at, format: :short %>
              </div>

              <div class="absolute bottom-2 left-2 md:bottom-4 md:left-4 bg-white/90 backdrop-blur-md text-orange-600 py-1 px-2.5 md:py-1.5 md:px-4 rounded-xl shadow-lg border border-orange-100 flex items-center gap-1">
                <span class="text-[8px] md:text-[10px] font-black uppercase tracking-tighter opacity-70">累計節約額</span>
                <span class="text-xs md:text-xl font-black">¥<%= number_with_delimiter(total_savings) %></span>
              </div>
            </div>

            <div class="p-4 md:p-6 flex-grow flex flex-col">
              <h2 class="text-sm md:text-lg font-black text-stone-800 mb-3 line-clamp-2">
                <% if recipe %>
                  <%= link_to recipe.title, recipe_path(recipe), class: "hover:text-orange-600 transition-colors" %>
                <% else %>
                  <span class="text-stone-400 italic">削除されたレシピ</span>
                <% end %>
              </h2>

              <div class="mt-auto p-3 bg-[#FFFBF7] rounded-2xl border border-orange-100/50">
                <div class="flex justify-between items-baseline border-b border-orange-100/30 pb-1.5 mb-1.5">
                  <span class="text-[8px] md:text-[10px] text-stone-400 font-bold uppercase">累計自炊費</span>
                  <span class="text-xs md:text-md font-black text-stone-700">¥<%= number_with_delimiter(record.total_cooking_cost) %></span>
                </div>
                <div class="flex justify-between items-baseline">
                  <span class="text-[8px] md:text-[10px] text-stone-400 font-bold truncate mr-1 uppercase">累計比較対象</span>
                  <span class="text-[10px] md:text-sm font-bold text-stone-300 line-through">¥<%= number_with_delimiter(record.total_convenience_cost) %></span>
                </div>
              </div>
            </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-full py-24 text-center">
        <div class="text-5xl mb-4">📖</div>
        <p class="text-stone-400 font-bold">まだ自炊の記録がありません。<br>料理を作って記録してみましょう！</p>
        <%= link_to "レシピを探す", recipes_path, class: "mt-6 inline-block bg-orange-500 text-white px-8 py-3 rounded-2xl font-bold shadow-lg shadow-orange-100" %>
      </div>
    <% end %>
  </div>

  <div class="mt-16 mb-12 flex justify-center">
    <%= paginate @cooking_records if @cooking_records.respond_to?(:total_pages) %>
  </div>
</div>